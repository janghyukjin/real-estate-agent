# ============================================
# 부동산 AI 에이전트 환경변수 설정
# ============================================
# 이 파일을 .env로 복사한 뒤 실제 키를 입력하세요:
#   cp .env.example .env
#   그리고 .env 파일을 편집

# 1) 공공데이터포털 API 키 (국토부 실거래가 + 건축물대장)
#    https://www.data.go.kr 에서 발급 (무료, 즉시 승인)
#    아래 3개 API 모두 같은 키 사용:
#    - 아파트매매 실거래 상세 자료
#    - 아파트 전월세 실거래가 자료
#    - 건축물대장정보 서비스
DATA_GO_KR_API_KEY=your_api_key_here

# 2) Anthropic API 키 (Claude AI)
#    https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 3) 카카오 REST API 키 (지하철/학군/편의시설 조회) - 선택
#    https://developers.kakao.com 에서 발급 (무료)
KAKAO_REST_API_KEY=your_kakao_key_here
